{"file":"symB-000","run":2,"verdicts":[{"a":"1:1","b":"59:22","same":false,"reason":"البسملة صيغة استفتاح لا تقرير حكم، والثانية تقرر التوحيد وعلم الغيب والشهادة، فمضمونهما مختلف رغم اشتراك «الرحمن الرحيم»."},{"a":"1:2","b":"20:8","same":false,"reason":"الأولى ثناء بالحمد وربوبية العالمين، والثانية تقرير للتوحيد وحسن الأسماء، مضمونان مختلفان."},{"a":"1:2","b":"34:1","same":false,"reason":"الثانية تزيد مضمونًا مستقلاً (الحمد في الآخرة، الحكيم الخبير) لا وجود له في الأولى."},{"a":"1:2","b":"40:65","same":false,"reason":"عبارة الحمد في الثانية ذيلٌ لآية أطول تقرر التوحيد ودعوة الإخلاص في العبادة، ففحوى النص الكلي أوسع من مجرد الحمد."},{"a":"1:2","b":"45:36","same":true,"reason":"كلاهما يقرر عين المعنى: الحمد لله لأنه رب العالمين، والثانية مجرد تفصيل لفظي لمعنى العالمين (سماوات وأرض) دون إضافة مضمون جديد."},{"a":"1:7","b":"6:153","same":false,"reason":"الأولى دعاء بوصف الصراط بأهله المنعم عليهم، والثانية أمر باتباع الصراط الواحد واجتناب السبل، صياغة ومقصد مختلفان."},{"a":"1:7","b":"10:25","same":false,"reason":"الأولى دعاء بالهداية لصراط المنعم عليهم، والثانية خبر عن دعوة الله إلى دار السلام وهدايته من يشاء، مضمون مختلف."},{"a":"2:2","b":"6:155","same":false,"reason":"الأولى وصف للكتاب بنفي الريب وكونه هدى للمتقين، والثانية أمر باتباعه وتقوى الله رجاء الرحمة."},{"a":"2:2","b":"10:37","same":false,"reason":"الثانية تقرر أصل القرآن الإلهي وتصديقه لما قبله وتفصيله، بخلاف الأولى التي تصفه هدى للمتقين فقط."},{"a":"2:2","b":"32:2","same":false,"reason":"كل نص يخص الكتاب بوصف مختلف: هدى للمتقين في الأولى، وكونه من رب العالمين في الثانية، فليسا نفس المقرر."},{"a":"2:2","b":"39:23","same":false,"reason":"الثانية تصف أثر القرآن النفسي والجسدي في سياق أوسع، وذكر الهدى فيها إجمالي مختلف عن الوصف المباشر في الأولى."},{"a":"2:2","b":"39:33","same":false,"reason":"الثانية تصف الصادق والمصدق به بأنهم المتقون، وليست وصفًا لصفة الكتاب كالأولى."},{"a":"2:3","b":"13:22","same":false,"reason":"قائمة الصفات في الثانية تضيف الصبر ودفع السيئة بالحسنة وتحذف الإيمان بالغيب، فليست نفس الصفات."},{"a":"2:3","b":"22:35","same":false,"reason":"أول الوصفين مختلف: وجل القلوب عند الذكر في الثانية مقابل الإيمان بالغيب في الأولى، فالقائمتان غير متطابقتين."},{"a":"2:3","b":"22:41","same":false,"reason":"الثانية شرطية مرتبطة بالتمكين في الأرض وتذكر الزكاة والأمر بالمعروف، سياق وحكم مختلفان عن الوصف العام في الأولى."},{"a":"2:3","b":"27:3","same":false,"reason":"الزكاة غير الإنفاق العام، واليقين بالآخرة أخص من الإيمان بالغيب، فالقائمتان متقاربتان لا متطابقتان."},{"a":"2:3","b":"31:4","same":false,"reason":"نفس سبب الفرق مع الزوج المماثل: زكاة مقابل إنفاق عام، ويقين بالآخرة مقابل إيمان بالغيب."},{"a":"2:3","b":"35:29","same":false,"reason":"الثانية تبدأ بتلاوة الكتاب لا الإيمان بالغيب، وتضيف رجاء تجارة لن تبور، مضمون زائد ومختلف."},{"a":"2:3","b":"42:38","same":false,"reason":"الثانية تبدأ بالاستجابة لله وتضيف الشورى، عنصران لا وجود لهما في الأولى."},{"a":"2:4","b":"4:136","same":false,"reason":"الثانية أمر بالإيمان مع تهديد الكافر بالضلال البعيد وذكر الملائكة والرسل، خطاب وأداء مختلفان عن الوصف الخبري في الأولى."},{"a":"2:4","b":"28:52","same":false,"reason":"الثانية خاصة بأهل الكتاب الذين آمنوا بالقرآن، لا وصف عام للمؤمنين بما أنزل من قبل وبالآخرة."},{"a":"2:4","b":"64:8","same":false,"reason":"الثانية أمر مباشر بالإيمان بالله ورسوله والنور المنزل، لا وصف لصفة المؤمنين كما في الأولى."},{"a":"2:6","b":"7:193","same":false,"reason":"سياق الثانية عن دعاء الأصنام العاجزة عن الاستجابة، لا عن إصرار الكافرين على عدم الإيمان رغم الإنذار."},{"a":"2:6","b":"10:96","same":false,"reason":"الأولى تعلل عدم إيمانهم باستواء الإنذار وعدمه، والثانية تعلله بنفاذ كلمة الرب عليهم، سببان مختلفان وإن اتفقت الخاتمة."},{"a":"2:6","b":"18:56","same":false,"reason":"الثانية عن وظيفة الرسل العامة ومجادلة الكفار بالباطل، لا عن استواء الإنذار وعدمه."},{"a":"2:8","b":"12:106","same":false,"reason":"الأولى عن منافقين يدّعون الإيمان كذبًا، والثانية عن أكثرهم مؤمنون مع شرك مخالط، حالتان مختلفتان."},{"a":"2:8","b":"24:47","same":false,"reason":"الثانية تضيف مشهدًا سرديًا (تولي فريق منهم بعد القول) ومتعلق الإيمان فيها مختلف (الرسول والطاعة لا اليوم الآخر)."},{"a":"2:8","b":"29:11","same":false,"reason":"الثانية عن تمييز الله مستقبلاً بين المؤمنين والمنافقين بالابتلاء، لا عن دعوى الإيمان الكاذبة الحاضرة."},{"a":"2:9","b":"3:69","same":false,"reason":"الفاعل والفعل مختلفان: منافقون يخادعون الله والمؤمنين في الأولى، وطائفة من أهل الكتاب تريد إضلال المؤمنين في الثانية، واقعتان مختلفتان رغم تشابه القالب."},{"a":"2:9","b":"4:142","same":false,"reason":"الثانية تذكر مخادعة الله لهم جزاءً ومشهد الكسل في الصلاة، مضمون زائد ونتيجة مختلفة عن خداعهم أنفسهم فقط."},{"a":"2:9","b":"6:26","same":false,"reason":"الثانية عن نهي الناس عن اتباع الحق والابتعاد عنه فيهلكون أنفسهم، فعل ونتيجة مختلفان عن الخداع."},{"a":"2:9","b":"7:99","same":false,"reason":"الثانية تحذير من الأمن من مكر الله، موضوع مستقل عن خداع المنافقين أنفسهم."},{"a":"2:9","b":"10:36","same":false,"reason":"الثانية عن اتباع الظن بدل الحق، لا صلة مباشرة بخداع المنافقين أنفسهم."},{"a":"2:9","b":"13:42","same":false,"reason":"الثانية عن مكر الأمم السابقة وإحاطة الله بكل مكر، لا عن خداع المنافقين أنفسهم بجهلهم."},{"a":"2:15","b":"10:11","same":false,"reason":"السبب مختلف: استهزاء الله بهم جزاءً في الأولى، وإمهالهم لعدم رجائهم اللقاء في الثانية، رغم اتحاد خاتمة «في طغيانهم يعمهون»."},{"a":"2:16","b":"2:86","same":false,"reason":"كل آية تصف صفقة مختلفة (الضلالة بالهدى مقابل الدنيا بالآخرة) وعاقبة مختلفة (خسران التجارة مقابل عدم تخفيف العذاب)."},{"a":"2:16","b":"14:3","same":false,"reason":"الثانية تصف إيثار الدنيا والصد عن سبيل الله وابتغاء العوج، لا شراء الضلالة بالهدى كالأولى."},{"a":"2:19","b":"2:20","same":false,"reason":"الآيتان جزءان متتاليان من تمثيل واحد ممتد لا تقريران مستقلان، والثانية تضيف تفصيلات جديدة (خطف البرق، مشيهم عند الإضاءة، قدرة الله)."},{"a":"2:19","b":"13:12","same":false,"reason":"الثانية آية كونية عامة عن البرق خوفًا وطمعًا، لا تمثيل لحال المنافقين كالأولى."},{"a":"2:19","b":"24:40","same":false,"reason":"تمثيلان مختلفان لمشهدين مختلفين (عاصفة ورعد مقابل ظلمات بحر) وموضوعهما مختلف، فاشتراك جنس التمثيل لا يكفي."}]}
{"file":"symA-000","run":2,"verdicts":[{"a":"1:1","b":"59:22","same":false,"reason":"البسملة صيغةُ استفتاحٍ للعمل، والأخرى تقريرٌ عقديٌّ في التوحيد وإحاطة العلم؛ مضمونان مختلفان."},{"a":"1:2","b":"20:8","same":false,"reason":"الأولى إثباتُ الحمد والربوبية العامة، والثانية إثباتُ التوحيد وانفراده بالأسماء الحسنى؛ لا تطابق في المقرَّر."},{"a":"1:2","b":"34:1","same":false,"reason":"الثانية تزيد مِلكيةَ السماوات والأرض والحمدَ في الآخرة والحكمةَ والخبرة، وهي مضامينُ مستقلة زائدة عن حمدِ الفاتحة."},{"a":"1:2","b":"40:65","same":false,"reason":"الثانية تضيف توحيدًا صريحًا وأمرًا بالإخلاص في الدعاء قبل جملة الحمد، فمضمونها أوسع من مجرد إثبات الحمد."},{"a":"1:2","b":"45:36","same":true,"reason":"كلاهما إثباتُ اختصاص الحمد بالله ربِّ العالمين، والثانية مجرد تفصيلٍ لعين معنى «رب العالمين» بذكر السماوات والأرض دون زيادة مضمون مستقل."},{"a":"1:7","b":"6:153","same":false,"reason":"الأولى دعاءٌ يصف صفةَ أهل الصراط (المنعَم عليهم لا المغضوب عليهم ولا الضالين)، والثانية أمرٌ باتباع الصراط وتحذيرٌ من تفرق السبل؛ وظيفتان مختلفتان."},{"a":"1:7","b":"10:25","same":false,"reason":"الأولى وصفُ صفات أهل الهداية في دعاء، والثانية إخبارٌ عن دعوة الله عمومَ الناس إلى دار السلام وهدايته من يشاء؛ مضمون مختلف."},{"a":"2:2","b":"6:155","same":false,"reason":"الأولى وصفٌ خبريٌّ لصفة الكتاب (لا ريب، هدى للمتقين)، والثانية أمرٌ باتباع الكتاب المبارك واتقاء الله؛ إنشاءٌ مقابل خبر ومضمون إضافي."},{"a":"2:2","b":"10:37","same":false,"reason":"الثانية دفاعٌ عن مصدر القرآن (نفي الافتراء وتصديق ما بين يديه وتفصيله) وهو مضمونٌ جدليٌّ مختلف عن وصف البقرة الافتتاحي."},{"a":"2:2","b":"32:2","same":false,"reason":"الثانية تُسنِد الكتاب صراحةً لكونه من رب العالمين في سياق نفي الافتراء، لا تصفه بأنه هدى للمتقين كالأولى؛ مقرَّران مختلفان."},{"a":"2:2","b":"39:23","same":false,"reason":"الثانية تصف الأثر النفسي للقرآن على الخاشعين واقترانَ الهداية بمشيئة الله، وهو مضمونٌ زائدٌ لا وجود له في الآية الأولى."},{"a":"2:2","b":"39:33","same":false,"reason":"الأولى تصفُ الكتاب، والثانية تُعرِّف المتقين بأنهم مَن جاء بالصدق وصدَّق به؛ موضوعان مختلفان رغم اشتراك لفظ «المتقين»."},{"a":"2:3","b":"13:22","same":false,"reason":"القائمة الثانية تُدخل الصبرَ ودفعَ السيئة بالحسنة وتُسقط الإيمانَ بالغيب، فهي مجموعة صفات مختلفة العناصر عن الأولى."},{"a":"2:3","b":"22:35","same":false,"reason":"الثانية تذكر وجل القلوب عند ذكر الله والصبر على المصائب بدل الإيمان بالغيب؛ عناصر مختلفة."},{"a":"2:3","b":"22:41","same":false,"reason":"الثانية شرطيةٌ خاصة بالتمكين في الأرض وتشمل الزكاة والأمر بالمعروف والنهي عن المنكر، مضمون سياسي اجتماعي مختلف عن صفات المتقين العامة."},{"a":"2:3","b":"27:3","same":false,"reason":"الثانية تجمع الزكاة واليقين بالآخرة (من آية أخرى غير 2:3) وتُسقط الإيمان بالغيب؛ لا تطابق مع مضمون 2:3 وحدها."},{"a":"2:3","b":"31:4","same":false,"reason":"نفس الاختلاف: الزكاة واليقين بالآخرة بدل الإيمان بالغيب والإنفاق العام."},{"a":"2:3","b":"35:29","same":false,"reason":"الثانية تضيف تلاوةَ الكتاب واستعارةَ التجارة التي لن تبور، وتُسقط الإيمان بالغيب؛ مضمون إضافي مختلف."},{"a":"2:3","b":"42:38","same":false,"reason":"الثانية تختص بالشورى بين المؤمنين، وهو عنصر لا وجود له في آية البقرة، فضلاً عن اختلاف باقي القائمة."},{"a":"2:4","b":"4:136","same":false,"reason":"الثانية أمرٌ صريح بالإيمان يضيف الملائكة والرسل صراحةً ووعيدَ الضلال البعيد على الكفر، وهو مضمون أوسع من الوصف الخبري في 2:4."},{"a":"2:4","b":"28:52","same":false,"reason":"الثانية خبرٌ خاص عن مَن أوتوا الكتاب من قبل القرآن وإيمانهم به، لا وصفٌ عام لصفة المتقين كالأولى."},{"a":"2:4","b":"64:8","same":false,"reason":"الثانية أمرٌ بالإيمان بالله ورسوله والنور المنزَّل دون ذكر الإيمان بالكتب السابقة أو اليقين بالآخرة كالأولى."},{"a":"2:6","b":"7:193","same":false,"reason":"الأولى عن إصرار الكفار على عدم الإيمان مهما أُنذروا، والثانية عن عجز الآلهة المزعومة عن الاستجابة لدعاء عابديها؛ مرجعان مختلفان تمامًا."},{"a":"2:6","b":"10:96","same":false,"reason":"الأولى تُسنِد الإصرارَ على الكفر إلى استواء الإنذار وعدمه، والثانية تُسنِده إلى نفاذ كلمة العذاب المقدَّرة عليهم؛ تعليلان مختلفان."},{"a":"2:6","b":"18:56","same":false,"reason":"الثانية عن وظيفة الرسل (تبشير وإنذار) وجدال الكفار بالباطل واستهزائهم بالآيات، مضمون مختلف عن ثبوت عدم إيمان طائفة بعينها."},{"a":"2:8","b":"12:106","same":false,"reason":"الأولى عن منافقين يكذبون في دعوى الإيمان بالكلية، والثانية عن مؤمنين بالله ظاهرًا مع وقوعهم في الشرك؛ حالتان مختلفتان."},{"a":"2:8","b":"24:47","same":false,"reason":"الثانية تضيف دعوى طاعة الرسول وشاهدَ التولي الفعلي عند التحاكم، وتُسقط ذكر اليوم الآخر؛ تفصيلٌ مختلف عن العموم في 2:8."},{"a":"2:8","b":"29:11","same":false,"reason":"الآية المقارَنة (29:11) عن علم الله بالمؤمنين والمنافقين عبر الفتنة، لا عن دعوى إيمانٍ كاذبة كالأولى؛ التشابه اللفظي في سياق الآية المجاورة لا في الآية نفسها."},{"a":"2:9","b":"3:69","same":false,"reason":"الفاعل مختلف (منافقون يخادعون الله والمؤمنين مقابل طائفة من أهل الكتاب يريدون إضلال المؤمنين)؛ تشابه الصيغة الختامية لا يعني وحدة المضمون."},{"a":"2:9","b":"4:142","same":false,"reason":"الثانية تصف مخادعةَ الله بأنّ الله خادعُهم وتضيف وصفَ كسل الصلاة والرياء وقلة الذكر، وهو مضمون إضافي غائب عن 2:9."},{"a":"2:9","b":"6:26","same":false,"reason":"الفعل والفاعل مختلفان (نهيٌ ونأيٌ عن القرآن يؤدي إلى هلاك النفس، لا مخادعةُ الله والمؤمنين)؛ تشابه الخاتمة فقط."},{"a":"2:9","b":"7:99","same":false,"reason":"الثانية عن الأمن من مكر الله وليست عن خداع المنافقين وعودته على أنفسهم؛ موضوعان متغايران."},{"a":"2:9","b":"10:36","same":false,"reason":"الثانية عن اتباع الظن بدل الحق، وهو مضمونٌ معرفي مختلف عن خداع المنافقين لأنفسهم."},{"a":"2:9","b":"13:42","same":false,"reason":"الثانية عن مكر الأمم السابقة وغلبة مكر الله عليه، لا عن خداع المنافقين أنفسهم دون شعور."},{"a":"2:15","b":"10:11","same":false,"reason":"الأولى تقرن الطغيان بالاستهزاء الإلهي جزاءً على استهزائهم، والثانية تقرنه بإمهال الله وعدم تعجيله بالشر رحمةً؛ سببان مختلفان رغم تطابق العبارة الختامية."},{"a":"2:16","b":"2:86","same":false,"reason":"العِوضان مختلفان (الضلالة بالهدى مقابل الحياة الدنيا بالآخرة) والجزاء مختلف (خسران التجارة مقابل عدم تخفيف العذاب)؛ مضمونان مستقلان."},{"a":"2:16","b":"14:3","same":false,"reason":"الثانية تصف إيثارَ الدنيا والصدَّ عن سبيل الله وابتغاء عوجه، وهو مضمون أوسع وأفعال إضافية غير موجودة في 2:16."},{"a":"2:19","b":"2:20","same":false,"reason":"آيتان متتاليتان في مَثَلٍ واحد لكن كلٌّ منهما تصف مشهدًا مختلفًا (الرعد والصواعق مقابل البرق الخاطف)؛ تكامل لا تكرار."},{"a":"2:19","b":"13:12","same":false,"reason":"الأولى ضمن مَثَل المنافقين، والثانية إخبارٌ عام عن آيات الله الكونية في البرق والسحاب دون علاقة بمَثَل النفاق."},{"a":"2:19","b":"24:40","same":false,"reason":"مَثَلان مختلفا الصورة (مطرٌ ورعدٌ للمنافقين مقابل ظلماتُ بحرٍ للكافرين) وإن اشتركا في جنس التمثيل بالظلمة."}]}
