   "location": "44:36",
   "score": 100,
   "textSnippet": "فأتوا بآبائنا إن كنتم صادقين"
  },
  {
   "location": "37:94",
   "score": 98.93,
   "textSnippet": "فأقبلوا إليه يزفون"
  },
  {
   "location": "37:99",
   "score": 86.61,
   "textSnippet": "وقال إني ذاهب إلى ربي سيهدين"
  },
  {
   "location": "56:31",
   "score": 83.85,
   "textSnippet": "وماء مسكوب"
  },
  {
   "location": "68:32",
   "score": 83.29,
   "textSnippet": "عسى ربنا أن يبدلنا خيرا منها إنا إلى ربنا راغبون"
  },
  {
   "location": "26:112",
   "score": 80.5,
   "textSnippet": "قال وما علمي بما كانوا يعملون"
  },
  {
   "location": "56:30",
   "score": 79.3,
   "textSnippet": "وظل ممدود"
  },
  {
   "location": "12:14",
   "score": 77.06,
   "textSnippet": "قالوا لئن أكله الذئب ونحن عصبة إنا إذا لخاسرون"
  },
  {
   "location": "102:3",
   "score": 76.11,
   "textSnippet": "كلا سوف تعلمون"
  },
  {
   "location": "69:8",
   "score": 75.64,
   "textSnippet": "فهل ترى لهم من باقية"
  },
  {
   "location": "26:155",
   "score": 74.8,
   "textSnippet": "قال هذه ناقة لها شرب ولكم شرب يوم معلوم"
  },
  {
   "location": "89:24",
   "score": 74.32,
   "textSnippet": "يقول يا ليتني قدمت لحياتي"
  },
  {
   "location": "11:80",
   "score": 74.28,
   "textSnippet": "قال لو أن لي بكم قوة أو آوي إلى ركن شديد"
  },
  {
   "location": "54:29",
   "score": 73.91,
   "textSnippet": "فنادوا صاحبهم فتعاطى فعقر"
  },
  {
   "location": "53:54",
   "score": 73.87,
   "textSnippet": "فغشاها ما غشى"
  },
  {
   "location": "20:27",
   "score": 73.67,
   "textSnippet": "واحلل عقدة من لساني"
  },
  {
   "location": "2:127",
   "score": 72.45,
   "textSnippet": "وإذ يرفع إبراهيم القواعد من البيت وإسماعيل ربنا تقبل منا إنك أنت السميع العليم"
  },
  {
   "location": "26:188",
   "score": 72.31,
   "textSnippet": "قال ربي أعلم بما تعملون"
  },
  {
   "location": "19:18",
   "score": 72.23,
   "textSnippet": "قالت إني أعوذ بالرحمن منك إن كنت تقيا"
  },
  {
   "location": "3:40",
   "score": 71.23,
   "textSnippet": "قال رب أنى يكون لي غلام وقد بلغني الكبر وامرأتي عاقر قال كذلك الله يفعل ما يشاء"
  },
  {
   "location": "18:32",
   "score": 70.93,
   "textSnippet": "واضرب لهم مثلا رجلين جعلنا لأحدهما جنتين من أعناب وحففناهما بنخل وجعلنا بينهما ز"
  },
  {
   "location": "57:26",
   "score": 69.59,
   "textSnippet": "ولقد أرسلنا نوحا وإبراهيم وجعلنا في ذريتهما النبوة والكتاب فمنهم مهتد وكثير منهم"
  },
  {
   "location": "102:4",
   "score": 68.42,
   "textSnippet": "ثم كلا سوف تعلمون"
  },
  {
   "location": "69:45",
   "score": 68.08,
   "textSnippet": "لأخذنا منه باليمين"
  },
  {
   "location": "74:9",
   "score": 67.86,
   "textSnippet": "فذلك يومئذ يوم عسير"
  },
  {
   "location": "53:60",
   "score": 67.79,
   "textSnippet": "وتضحكون ولا تبكون"
  },
  {
   "location": "26:57",
   "score": 67.33,
   "textSnippet": "فأخرجناهم من جنات وعيون"
  },
  {
   "location": "3:35",
   "score": 67.07,
   "textSnippet": "إذ قالت امرأت عمران رب إني نذرت لك ما في بطني محررا فتقبل مني إنك أنت السميع الع"
  },
  {
   "location": "37:124",
   "score": 66.98,
   "textSnippet": "إذ قال لقومه ألا تتقون"
  },
  {
   "location": "15:42",
   "score": 66.71,
   "textSnippet": "إن عبادي ليس لك عليهم سلطان إلا من اتبعك من الغاوين"
  }
 ],
